  "title": "Long-Context Attention Mechanisms Survey",
  "abstract": "Comparative analysis of sparse and linear attention mechanisms for long-context LLMs (100K-1M+ tokens). Covers Longformer, BigBird, LongNet, Linear Transformer, RWKV, and Mamba variants with complexity analysis and empirical bounds.",
  "content": {
    "sparse_attention": {
      "mechanisms": [
        {
          "name": "Longformer",
          "paper": "Beltagy et al. 2020",
          "complexity": "O(n)",
          "max_tested_context": "16K tokens",
          "key_tradeoff": "Fixed local+global pattern, less flexible"
        },
        {
          "name": "BigBird",
          "paper": "Zaheer et al. 2020",
          "complexity": "O(n)",
          "max_tested_context": "4K tokens",
          "key_tradeoff": "Random+window+global, needs tuning"
        },
        {
          "name": "Sparse Transformer",
          "paper": "Child et al. 2019",
          "complexity": "O(n√n)",
          "max_tested_context": "16K (audio domain)",
          "key_tradeoff": "Factorized attention, domain-specific patterns"
        },
        {
          "name": "LongNet",
          "paper": "Ding et al. 2023",
          "complexity": "O(n)",
          "max_tested_context": "1B tokens (claimed)",
          "key_tradeoff": "Dilated attention, limited independent validation"
        }
      ],
      "summary": "Sparse methods achieve O(n) complexity but most validated benchmarks cap at 16-64K tokens."
    },
    "linear_attention": {
      "mechanisms": [
        {
          "name": "Linear Transformer",
          "paper": "Katharopoulos et al. 2020",
          "complexity": "O(n)",
          "max_tested_context": "4K tokens",
          "key_tradeoff": "No softmax, quality degradation on long sequences"
        },
        {
          "name": "RWKV",
          "paper": "Peng et al. 2023",
          "complexity": "O(n)",
          "max_tested_context": "100K+ tokens",
          "key_tradeoff": "RNN-like state, proven at scale"
        },
        {
          "name": "Mamba",
          "paper": "Gu & Dao 2023",
          "complexity": "O(n)",
          "max_tested_context": "1M tokens",
          "key_tradeoff": "State-space model, hardware-efficient, strong benchmarks"
        }
      ],
      "summary": "Linear/SSM methods show more promise for 1M+ contexts with Mamba leading in validated performance."
    },
    "recommendation": {
      "for_1m_plus_tokens": "Mamba-class SSM architectures",
      "rationale": "Best validated performance at extreme context lengths, hardware-efficient inference, proven training stability",
      "caveat": "Hybrid sparse+SSM approaches emerging as strong contenders"
    }
  },
